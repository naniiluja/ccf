{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "plugins/ccf/hooks/**/*.mjs",
    "plugins/ccf/templates/root/.claude/hooks/lib/**/*.mjs",
    "bin/**/*.mjs"
  ],
  "exclude": ["**/*.test.mjs"]
}
